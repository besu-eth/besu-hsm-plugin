%% Besu HSM Plugin — Architecture
%% Render: npx -y -p @mermaid-js/mermaid-cli mmdc -i docs/besu-hsm-plugin-architecture.mmd -o docs/besu-hsm-plugin-architecture.png -w 1600 -b white
flowchart TB
    classDef besu fill:#cfe2ff,stroke:#0d6efd,color:#000
    classDef plugin fill:#bee3db,stroke:#2a9d8f,color:#000
    classDef abstract fill:#e9ecef,stroke:#495057,color:#000,font-style:italic
    classDef jca fill:#fff3cd,stroke:#b58900,color:#000
    classDef hsm fill:#ffd7a8,stroke:#cc5500,color:#000
    classDef ffm fill:#e0d5f5,stroke:#6f42c1,color:#000

    besu["<b>Besu QBFT Validator</b><br/>P2P (RLPx) handshake — ECDH<br/>QBFT consensus messages — sign"]:::besu
    api(["<b>Besu Plugin API</b><br/>SecurityModuleService"]):::abstract

    subgraph plugin["besu-hsm-plugin"]
        direction TB
        secModule["<b>HsmSecurityModule</b><br/>sign · getPublicKey · ECDH"]:::plugin
        provider(["<b>HsmProvider</b> «interface»"]):::abstract
        nativeImpl["<b>NativePkcs11Provider</b><br/><i>native-pkcs11 (default)</i><br/>any PKCS#11 HSM via Java 25 FFM"]:::plugin
        cloudHsmImpl["<b>CloudHsmJceProvider</b><br/><i>cloudhsm-jce</i>"]:::plugin
        pkcs11Impl["<b>Pkcs11Provider</b><br/><i>generic-pkcs11 (dev/test)</i><br/>SunPKCS11-based"]:::plugin
        nativeFfm["<b>Pkcs11Ffm</b><br/>java.lang.foreign binding<br/>direct dlopen of vendor PKCS#11 lib"]:::ffm
    end

    sunpkcs11["<b>SunPKCS11</b><br/>JCA Provider (JDK)"]:::jca
    cloudHsmJce["<b>AWS CloudHSM</b><br/>JCE Provider"]:::jca

    pkcs11Hsm["<b>PKCS#11 HSM</b><br/>Thales Luna · SoftHSM2<br/>YubiHSM2 · Azure Dedicated HSM<br/>Google Cloud HSM"]:::hsm
    awsCloudHsm["<b>AWS CloudHSM Cluster</b>"]:::hsm
    softhsm["<b>SoftHSM2</b><br/>(dev/test only)"]:::hsm

    besu -->|"sign · getPublicKey · ECDH"| api
    api --> secModule
    secModule --> provider
    provider -.->|implemented by| nativeImpl
    provider -.->|implemented by| cloudHsmImpl
    provider -.->|implemented by| pkcs11Impl

    nativeImpl --> nativeFfm
    cloudHsmImpl -->|"Security.addProvider"| cloudHsmJce
    pkcs11Impl -->|"Security.addProvider"| sunpkcs11

    nativeFfm -->|"PKCS#11 v2.40 calls<br/>(C_Sign · C_DeriveKey ·<br/>C_WrapKey · C_Decrypt)"| pkcs11Hsm
    cloudHsmJce -->|"CloudHSM client SDK"| awsCloudHsm
    sunpkcs11 -->|"libsofthsm2.so"| softhsm
